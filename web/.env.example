# PostHog (optional) — used at `npm run build` / Docker web build stage
VITE_POSTHOG_API_KEY=phc_your_project_key
VITE_POSTHOG_HOST=https://eu.i.posthog.com
VITE_POSTHOG_DISABLE_SESSION_RECORDING=true
VITE_POSTHOG_AUTOCAPTURE=false

# Vite dev server only (Go proxy not injecting index.html)
# VITE_POSTHOG_ENABLED=true
